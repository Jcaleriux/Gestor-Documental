# Backend runtime
NODE_ENV=production
PORT=3002

# Database
DB_HOST=change-this-before-production
DB_PORT=5432
DB_USER=change-this-before-production
DB_PASSWORD=change-this-before-production
DB_NAME=change-this-before-production

# Auth
JWT_SECRET=change-this-before-production
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=https://app.example.com

# Files and operational limits
FACTURAS_BASE_DIR=change-this-before-production
JSON_BODY_LIMIT=20mb
PERMISSIONS_CACHE_TTL_MS=60000
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX=20
TABLAS_PAGO_MAX_FILE_MB=10
ORDENES_COMPRA_MAX_FILE_MB=10
RESERVAS_DOC_MAX_FILE_MB=15
WATCHER_SCAN_DEBOUNCE_MS=600
WATCHER_LATE_FILES_DELAY_MS=2000
WATCHER_AWF_STABILITY_MS=2000
WATCHER_AWF_POLL_MS=100
