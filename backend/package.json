{
    "name": "sendadocs-backend",
    "version": "1.0.0",
    "description": "Backend SendaDocs",
    "main": "index.js",
    "type": "commonjs",
    "scripts": {
        "db:init": "node db/create_tables.js",
        "db:reset": "node db/reset_schema.js",
        "db:check": "node db/check_structure.js",
        "db:migrate": "node db/migrate.js",
        "db:migrate:status": "node db/migrate_status.js",
        "importar": "node scripts/importarFactura.js",
        "watcher": "node scripts/watcher.js",
        "proveedores:backfill": "node scripts/backfill_proveedores.js",
        "reindex": "node scripts/reindex_rutas.js",
        "diagnostico": "node scripts/diagnostico_docs.js",
        "auditar:facturas-rutas": "node scripts/auditar_rutas_facturas.js",
        "smoke:facturas": "node scripts/smoke_facturas_list.js",
        "reporte-duplicados": "node scripts/reporte_duplicados.js",
        "reset-docs": "node scripts/reset_documentos.js",
        "reset-facturas-prueba:dry-run": "node scripts/reset_facturas_prueba.js --dry-run",
        "server": "node server.js",
        "dev": "node server.js",
        "preprod:setup": "node scripts/setup_local_preproduction.js",
        "preprod:start": "node scripts/run_with_env_file.js --env-file .env.production.local server.js",
        "preprod:db:init": "node scripts/run_with_env_file.js --env-file .env.production.local db/create_tables.js",
        "preprod:db:check": "node scripts/run_with_env_file.js --env-file .env.production.local db/check_structure.js",
        "preprod:db:migrate": "node scripts/run_with_env_file.js --env-file .env.production.local db/migrate.js",
        "preprod:backup-plan": "node scripts/run_with_env_file.js --env-file .env.production.local scripts/release_backup_plan.js",
        "preprod:readiness": "node scripts/run_with_env_file.js --env-file .env.production.local scripts/release_readiness_report.js --env-file .env.production.local",
        "preprod:smoke": "node scripts/run_with_env_file.js --env-file .env.production.local scripts/release_smoke_checks.js",
        "check:release": "node scripts/release_checks.js",
        "release:backup-plan": "node scripts/release_backup_plan.js",
        "release:readiness": "node scripts/release_readiness_report.js",
        "release:smoke": "node scripts/release_smoke_checks.js",
        "test": "jest",
        "test:ci": "node node_modules/jest/bin/jest.js --runInBand",
        "test:coverage": "node node_modules/jest/bin/jest.js --runInBand --coverage --coverageReporters=text --coverageReporters=text-summary --coverageReporters=json-summary"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "chokidar": "^5.0.0",
        "cors": "^2.8.5",
        "express": "^4.22.2",
        "fast-xml-parser": "^5.7.0",
        "fs-extra": "^11.3.3",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.0",
        "nodemailer": "^9.0.1",
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^2.4.5",
        "pg": "^8.11.5"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "supertest": "^7.1.3"
    }
}
