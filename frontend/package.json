    "qa:contabilizacion": "node scripts/visual_qa_contabilizacion.mjs"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.18.0",
    "bootstrap": "^5.3.8",
    "exceljs": "^4.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.2"
  }
